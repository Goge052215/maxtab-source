  margin-bottom: 20px;
}

.menu-item {
  display: flex;
  min-height: 95px;
  width: 100%;
  background-color: #222222;
  border-radius: 12px;
  padding: 15px 20px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 1px solid #333333;
}

.menu-label {
  font-size: 24px;
