<import name="input-method" src="../../../components/InputMethod/InputMethod.ux"></import>

<template>
  <div class="container" @swipe="handleSwipe">
    <div class="top-bar">
      <div class="title-container">
        <text class="title">{{ i18n.pages.hypothesis.linear_regression }}</text>
        <text class="subtitle">{{ i18n.pages.hypothesis.input_mode }}</text>
      </div>
    </div>

    <scroll class="scroll-container" scroll-y="true">
      <div class="scroll-content">
        <div class="content">
          
          <div class="param-section" if="{{ !showKeyboard }}">
            <div class="table-header">
              <text class="table-cell-id">#</text>
              <text class="table-cell-value">X</text>
              <text class="table-cell-value">Y</text>
            </div>
            
            <div class="table-row" for="{{ (index, item) in dataArray }}">
              <text class="table-cell-id">{{ index + 1 }}</text>
              <div class="table-cell-input" @click="selectArrayInput(index, 'x')">
                <text class="param-value">{{ item.x === null ? '' : item.x }}</text>
              </div>
              <div class="table-cell-input" @click="selectArrayInput(index, 'y')">
                <text class="param-value">{{ item.y === null ? '' : item.y }}</text>
              </div>
            </div>
            
            <div class="table-actions">
              <div class="action-btn" onclick="addRow">
                <text class="action-text">+</text>
              </div>
              <div class="action-btn" onclick="removeRow">
                <text class="action-text">-</text>
              </div>
            </div>
          </div>

          <div class="param-section" if="{{ showKeyboard }}">
            <div class="param-item">
              <text class="param-label">{{ currentParamName }}</text>
              <div class="param-display">
                <text class="param-value">{{ inputBuffer }}</text>
              </div>
            </div>
          </div>

          <div class="calc-section" if="{{ !showKeyboard }}">
            <div class="calc-btn" onclick="calculate">
              <text class="calc-text">{{ i18n.common.calculate }}</text>
            </div>
          </div>

          <div class="result-section" if="{{ !showKeyboard && hasResult }}">
            <text class="result-title">{{ i18n.common.calculation_result }}</text>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.slope }} (b1)</text>
                <text class="menu-value result-number">{{ resultSlope }}</text>
              </div>
            </div>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.intercept }} (b0)</text>
                <text class="menu-value result-number">{{ resultIntercept }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.correlation }}</text>
                <text class="menu-value result-number">{{ resultR }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.r_squared }}</text>
                <text class="menu-value result-number">{{ resultRSquared }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.p_value }} (Slope)</text>
                <text class="menu-value result-number">{{ pValue }}</text>
              </div>
            </div>

            <div class="menu-list-item" if="{{ lowerCISlope !== null }}">
              <div class="menu-item">
                <text class="menu-label">Slope 95% CI</text>
                <text class="menu-value small-text result-number">[{{ lowerCISlope }}, {{ upperCISlope }}]</text>
              </div>
            </div>

            <div class="menu-list-item highlight">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.conclusion }} (α=0.05)</text>
                <text class="menu-value small-text result-number">{{ conclusion }}</text>
              </div>
            </div>
          </div>

          <div class="error-message" if="{{ errorMessage }}">
            <text class="error-text">{{ errorMessage }}</text>
          </div>

          <div class="bottom-section" if="{{ !showKeyboard }}">
            <div class="back-btn" onclick="goBack">
              <text class="back-text">{{ i18n.common.back }}</text>
            </div>
          </div>
          
          <input-method
            if="{{ showKeyboard }}"
            hide="{{!showKeyboard}}"
            keyboardtype="NUMERIC"
            maxlength="10"
            vibratemode="{{vibratemode}}"
            screentype="{{screentype}}"
            @visibility-change="onVisibilityChange"
            @key-down="onKeyDown"
            @delete="onDelete"
            @complete="onComplete"
          ></input-method>
        </div>
      </div>
    </scroll>
  </div>
</template>

<script>
import router from "@system.router"
import i18n from "../../../common/i18n"
import HypothesisEngine from "../../../common/hypothesis_engine"

export default {
  private: {
    dataArray: [
      { x: null, y: null },
      { x: null, y: null },
      { x: null, y: null },
      { x: null, y: null }
    ],
    showKeyboard: false,
    currentParamName: '',
    currentArrayIndex: -1,
    currentArrayField: '', // 'x' or 'y'
    inputBuffer: '',
    originalValue: null,
    
    // Results
    hasResult: false,
    resultSlope: "-",
    resultIntercept: "-",
    resultR: "-",
    resultRSquared: "-",
    pValue: "-",
    lowerCISlope: null,
    upperCISlope: null,
    conclusion: "",
    errorMessage: "",
    alpha: 0.05,

    i18n: i18n.getLocaleStrings(),
    vibratemode: "short",
    screentype: "pill-shaped"
  },

  onInit() {
    this.refreshI18n()
  },

  onShow() {
    this.refreshI18n()
  },

  refreshI18n() {
    this.i18n = i18n.getLocaleStrings()
    this.$page.setTitleBar({ text: i18n.t('pages.hypothesis.linear_regression') })
    this.$forceUpdate()
  },

  goBack() {
    router.back()
  },

  handleSwipe(event) {
    if (event.direction === 'right') {
      this.goBack()
    }
  },

  addRow() {
    this.dataArray.push({ x: null, y: null })
  },

  removeRow() {
    if (this.dataArray.length > 3) {
      this.dataArray.pop()
    }
  },

  selectArrayInput(index, field) {
    this.currentArrayIndex = index
    this.currentArrayField = field
    this.originalValue = this.dataArray[index][field]
    this.inputBuffer = ''
    this.showKeyboard = true
    const fieldName = field.toUpperCase()
    this.currentParamName = `${fieldName} [${index + 1}]`
  },

  onVisibilityChange(e) {
    if (!e.detail.visible) {
      this.showKeyboard = false
      this.inputBuffer = ''
      this.$forceUpdate()
    }
  },

  onKeyDown(e) {
    // Log key
  },

  onDelete() {
    if (this.inputBuffer.length > 0) {
      this.inputBuffer = this.inputBuffer.slice(0, -1)
      this.updateParameterFromBuffer()
    } else {
      if (this.currentArrayIndex >= 0) {
        const item = this.dataArray[this.currentArrayIndex]
        item[this.currentArrayField] = null
        this.dataArray.splice(this.currentArrayIndex, 1, item)
      }
    }
    this.$forceUpdate()
  },

  onComplete(e) {
    if (e.detail && e.detail.isCompleteButton) {
      this.onFinish()
      return
    }

    const char = e.detail.content
    
    if (char === '.' && this.inputBuffer.indexOf('.') !== -1) return
    
    // Allow negative numbers for regression
    if (char === '-' && this.inputBuffer.length === 0) {
      this.inputBuffer = char
      this.updateParameterFromBuffer()
      this.$forceUpdate()
      return
    }
    
    if (char === '-') return 

    if (this.inputBuffer === '0' && char !== '.') {
      this.inputBuffer = char
    } else if (this.inputBuffer === '0' && char === '.') {
      this.inputBuffer = '0.'
    } else {
      this.inputBuffer += char
    }
    
    this.updateParameterFromBuffer()
    this.$forceUpdate()
  },

  updateParameterFromBuffer() {
    if (!this.inputBuffer || this.inputBuffer === '' || this.inputBuffer === '-') return
    
    const value = parseFloat(this.inputBuffer)
    if (isNaN(value)) return
    
    if (this.currentArrayIndex >= 0) {
      const item = this.dataArray[this.currentArrayIndex]
      item[this.currentArrayField] = value
      this.dataArray.splice(this.currentArrayIndex, 1, item)
    }
  },

  onFinish() {
    if (this.inputBuffer === '' && this.originalValue !== undefined) {
      const item = this.dataArray[this.currentArrayIndex]
      item[this.currentArrayField] = this.originalValue
      this.dataArray.splice(this.currentArrayIndex, 1, item)
    }
    
    this.showKeyboard = false
    this.inputBuffer = ''
    this.$forceUpdate()
  },

  calculate() {
    try {
      this.errorMessage = ""
      this.hasResult = false

      const x = []
      const y = []

      for (let i = 0; i < this.dataArray.length; i++) {
        const item = this.dataArray[i]
        if (item.x !== null && item.y !== null) {
          x.push(parseFloat(item.x))
          y.push(parseFloat(item.y))
        }
      }

      if (x.length < 3) {
        this.errorMessage = "Need at least 3 pairs of data"
        return
      }

      const result = HypothesisEngine.linearRegression(x, y)

      if (result.error) {
        this.errorMessage = this.i18n.common.error_failed + ": " + result.error
        return
      }

      this.resultSlope = result.slope.toFixed(4)
      this.resultIntercept = result.intercept.toFixed(4)
      this.resultR = result.r.toFixed(4)
      this.resultRSquared = result.rSquared.toFixed(4)
      this.pValue = result.pValueTwoTail.toFixed(4)
      
      if (result.lowerCISlope !== null && result.upperCISlope !== null) {
        this.lowerCISlope = result.lowerCISlope.toFixed(4)
        this.upperCISlope = result.upperCISlope.toFixed(4)
      } else {
        this.lowerCISlope = null
        this.upperCISlope = null
      }

      if (result.pValueTwoTail < this.alpha) {
        this.conclusion = this.i18n.pages.hypothesis.reject
      } else {
        this.conclusion = this.i18n.pages.hypothesis.fail_to_reject
      }

      this.hasResult = true
    } catch (e) {
      this.errorMessage = "Calculation Error: " + (e.message || e)
      this.hasResult = false
    }
  }
}
</script>

