  height: 70px;
  width: 100%;
  background-color: #0066cc;
  border-radius: 12px;
  padding: 15px 20px;
  justify-content: center;
  align-items: center;
}

.calc-text {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
}

.result-section {
  margin-top: 20px;
  background-color: #1a1a1a;
  border-radius: 12px;
  padding: 15px;
  border: 1px solid #333333;
  flex-direction: column;
}

.result-title {
  font-size: 24px;
  color: #00ff88;
  font-weight: bold;
  margin-bottom: 15px;
  text-align: center;
  width: 100%;
}

