<import name="input-method" src="../../../components/InputMethod/InputMethod.ux"></import>

<template>
  <div class="container" @swipe="handleSwipe">
    <div class="top-bar">
      <div class="title-container">
        <text class="title">{{ i18n.pages.hypothesis.chi_square }}</text>
        <text class="subtitle">{{ i18n.pages.hypothesis.input_mode }}</text>
      </div>
    </div>

    <scroll class="scroll-container" scroll-y="true">
      <div class="scroll-content">
        <div class="content">
          
          <!-- Data Input Table -->
          <div class="param-section" if="{{ !showKeyboard }}">
            <div class="table-header">
              <text class="table-cell-id">#</text>
              <text class="table-cell-value">{{ i18n.pages.hypothesis.observed }}</text>
              <text class="table-cell-value">{{ i18n.pages.hypothesis.expected }}</text>
            </div>
            
            <div class="table-row" for="{{ (index, item) in dataArray }}">
              <text class="table-cell-id">{{ index + 1 }}</text>
              <div class="table-cell-input" @click="selectArrayInput(index, 'obs')">
                <text class="param-value">{{ item.obs === null ? '' : item.obs }}</text>
              </div>
              <div class="table-cell-input" @click="selectArrayInput(index, 'exp')">
                <text class="param-value">{{ item.exp === null ? '' : item.exp }}</text>
              </div>
            </div>
            
            <div class="table-actions">
              <div class="action-btn" onclick="addRow">
                <text class="action-text">+</text>
              </div>
              <div class="action-btn" onclick="removeRow">
                <text class="action-text">-</text>
              </div>
            </div>
          </div>

          <!-- Keyboard Input Display -->
          <div class="param-section" if="{{ showKeyboard }}">
            <div class="param-item">
              <text class="param-label">{{ currentParamName }}</text>
              <div class="param-display">
                <text class="param-value">{{ inputBuffer }}</text>
              </div>
            </div>
          </div>

          <!-- Calculate Button -->
          <div class="calc-section" if="{{ !showKeyboard }}">
            <div class="calc-btn" onclick="calculate">
              <text class="calc-text">{{ i18n.common.calculate }}</text>
            </div>
          </div>

          <!-- Results Section -->
          <div class="result-section" if="{{ !showKeyboard && hasResult }}">
            <text class="result-title">{{ i18n.common.calculation_result }}</text>
            
            <div class="result-item">
              <text class="result-label">Chi-Square (χ²)</text>
              <text class="result-value">{{ resultChiSq }}</text>
            </div>
            
            <div class="result-item">
              <text class="result-label">df</text>
              <text class="result-value">{{ resultDf }}</text>
            </div>

            <div class="result-item">
              <text class="result-label">{{ i18n.pages.hypothesis.p_value }}</text>
              <text class="result-value">{{ pValue }}</text>
            </div>

            <div class="result-item highlight">
              <text class="result-label">{{ i18n.pages.hypothesis.conclusion }} (α=0.05)</text>
              <text class="result-value small-text">{{ conclusion }}</text>
            </div>
          </div>

          <!-- Error Message -->
          <div class="error-message" if="{{ errorMessage }}">
            <text class="error-text">{{ errorMessage }}</text>
          </div>

          <!-- Back Button -->
          <div class="bottom-section" if="{{ !showKeyboard }}">
            <div class="back-btn" onclick="goBack">
              <text class="back-text">{{ i18n.common.back }}</text>
            </div>
          </div>
          
          <input-method
            if="{{ showKeyboard }}"
            hide="{{!showKeyboard}}"
            keyboardtype="NUMERIC"
            maxlength="10"
            vibratemode="{{vibratemode}}"
            screentype="{{screentype}}"
            @visibility-change="onVisibilityChange"
            @key-down="onKeyDown"
            @delete="onDelete"
            @complete="onComplete"
          ></input-method>
        </div>
      </div>
    </scroll>
  </div>
</template>

<script>
import router from "@system.router"
import i18n from "../../../common/i18n"
import HypothesisEngine from "../../../common/hypothesis_engine"

export default {
  private: {
    dataArray: [
      { obs: null, exp: null },
      { obs: null, exp: null },
      { obs: null, exp: null }
    ],
    showKeyboard: false,
    currentParamName: '',
    currentArrayIndex: -1,
    currentArrayField: '', // 'obs' or 'exp'
    inputBuffer: '',
    originalValue: null,
    
    // Results
    hasResult: false,
    resultChiSq: "-",
    resultDf: "-",
    pValue: "-",
    conclusion: "",
    errorMessage: "",
    alpha: 0.05,

    i18n: i18n.getLocaleStrings(),
    vibratemode: "short",
    screentype: "pill-shaped"
  },

  onInit() {
    this.refreshI18n()
  },

  onShow() {
    this.refreshI18n()
  },

  refreshI18n() {
    this.i18n = i18n.getLocaleStrings()
    this.$page.setTitleBar({ text: i18n.t('pages.hypothesis.chi_square') })
    this.$forceUpdate()
  },

  goBack() {
    router.back()
  },

  handleSwipe(event) {
    if (event.direction === 'right') {
      this.goBack()
    }
  },

  addRow() {
    this.dataArray.push({ obs: null, exp: null })
  },

  removeRow() {
    if (this.dataArray.length > 2) {
      this.dataArray.pop()
    }
  },

  selectArrayInput(index, field) {
    this.currentArrayIndex = index
    this.currentArrayField = field
    this.originalValue = this.dataArray[index][field]
    this.inputBuffer = ''
    this.showKeyboard = true
    const fieldName = field === 'obs' ? this.i18n.pages.hypothesis.observed : this.i18n.pages.hypothesis.expected
    this.currentParamName = `${fieldName} [${index + 1}]`
  },

  onVisibilityChange(e) {
    if (!e.detail.visible) {
      this.showKeyboard = false
      this.inputBuffer = ''
      this.$forceUpdate()
    }
  },

  onKeyDown(e) {
    // Log key
  },

  onDelete() {
    if (this.inputBuffer.length > 0) {
      this.inputBuffer = this.inputBuffer.slice(0, -1)
      this.updateParameterFromBuffer()
    } else {
      if (this.currentArrayIndex >= 0) {
        const item = this.dataArray[this.currentArrayIndex]
        item[this.currentArrayField] = null
        this.dataArray.splice(this.currentArrayIndex, 1, item)
      }
    }
    this.$forceUpdate()
  },

  onComplete(e) {
    if (e.detail && e.detail.isCompleteButton) {
      this.onFinish()
      return
    }

    const char = e.detail.content
    
    if (char === '.' && this.inputBuffer.indexOf('.') !== -1) return
    
    // No negative numbers for counts usually, but let's allow just in case logic changes
    // But Chi-Square observed counts must be non-negative.
    if (char === '-') return 

    if (this.inputBuffer === '0' && char !== '.') {
      this.inputBuffer = char
    } else if (this.inputBuffer === '0' && char === '.') {
      this.inputBuffer = '0.'
    } else {
      this.inputBuffer += char
    }
    
    this.updateParameterFromBuffer()
    this.$forceUpdate()
  },

  updateParameterFromBuffer() {
    if (!this.inputBuffer || this.inputBuffer === '') return
    
    const value = parseFloat(this.inputBuffer)
    if (isNaN(value)) return
    
    if (this.currentArrayIndex >= 0) {
      const item = this.dataArray[this.currentArrayIndex]
      item[this.currentArrayField] = value
      this.dataArray.splice(this.currentArrayIndex, 1, item)
    }
  },

  onFinish() {
    if (this.inputBuffer === '' && this.originalValue !== undefined) {
      const item = this.dataArray[this.currentArrayIndex]
      item[this.currentArrayField] = this.originalValue
      this.dataArray.splice(this.currentArrayIndex, 1, item)
    }
    
    this.showKeyboard = false
    this.inputBuffer = ''
    this.$forceUpdate()
  },

  calculate() {
    try {
      this.errorMessage = ""
      this.hasResult = false

      const observed = []
      const expected = []

      for (let i = 0; i < this.dataArray.length; i++) {
        const item = this.dataArray[i]
        if (item.obs !== null && item.exp !== null) {
          observed.push(parseFloat(item.obs))
          expected.push(parseFloat(item.exp))
        }
      }

      if (observed.length < 2) {
        this.errorMessage = "Need at least 2 pairs of data"
        return
      }

      const result = HypothesisEngine.chiSquareGoodnessOfFit(observed, expected)

      if (result.error) {
        this.errorMessage = this.i18n.common.error_failed + ": " + result.error
        return
      }

      this.resultChiSq = result.chiSquare.toFixed(4)
      this.resultDf = result.df
      this.pValue = result.pValue.toFixed(4)

      if (result.pValue < this.alpha) {
        this.conclusion = this.i18n.pages.hypothesis.reject
      } else {
        this.conclusion = this.i18n.pages.hypothesis.fail_to_reject
      }

      this.hasResult = true
    } catch (e) {
      this.errorMessage = "Calculation Error: " + (e.message || e)
      this.hasResult = false
    }
  }
}
</script>

