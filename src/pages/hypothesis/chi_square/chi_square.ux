  padding: 15px 20px;
  justify-content: center;
  align-items: center;
}

.calc-text {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
}

.result-section {
  margin-top: 20px;
  background-color: #1a1a1a;
  border-radius: 12px;
  padding: 15px;
  border: 1px solid #333333;
  flex-direction: column;
}

.result-title {
    font-size: 24px;
