  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
}

.main-menu {
  display: flex;
  flex: 1;
  flex-direction: column;
  height: 0;
}

.scroll-container {
  flex: 1;
  width: 100%;
  flex-direction: column;
}

.menu-content {
  padding: 20px 20px 40px 20px;
  flex-direction: column;
}

.menu-header {
  margin-bottom: 20px;
  align-items: center;
  justify-content: center;
}

.menu-subtitle {
  color: #ffffff;
  font-size: 24px;
  font-weight: bold;
}

