  display: flex;
  flex-direction: column;
  background-color: #000000;
  height: 100%;
}

.top-bar {
  height: 80px;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 15px 20px;
}

.title {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
}

.scroll-container {
  flex: 1;
  width: 100%;
  flex-direction: column;
}

.scroll-content {
  flex-direction: column;
  width: 100%;
}

.content {
  flex-direction: column;
  padding: 16px 12px;
}

.section-group {
  flex-direction: column;
  margin-bottom: 20px;
}

.section-title {
  font-size: 24px;
  color: #aaaaaa;
  margin-bottom: 10px;
  font-weight: bold;
}

.menu-list-item {
  margin-bottom: 20px;
}

.menu-item {
  display: flex;
  min-height: 95px;
  width: 100%;
  background-color: #222222;
  border-radius: 12px;
  padding: 15px 20px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 1px solid #333333;
}

.menu-label {
  font-size: 24px;
  color: #ffffff;
}

.menu-value {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
  text-align: center;
}

.menu-value.result-number {
  font-size: 30px;
}

.menu-value.small-text {
  font-size: 20px;
}

.menu-value.small-text.result-number {
  font-size: 24px;
}
.result-section {
  flex-direction: column;
  margin-bottom: 20px;
  background-color: #1a1a1a;
  border-radius: 12px;
  padding: 15px;
  border: 1px solid #333333;
}

.result-title {
  font-size: 24px;
  color: #00ff88;
  margin-bottom: 15px;
  font-weight: bold;
  text-align: center;
}

.menu-list-item.highlight .menu-item {
  border-color: #444444;
}

.error-message {
  padding: 20px;
  background-color: #331111;
  border-radius: 8px;
  margin-bottom: 20px;
}

.error-text {
  color: #ff4444;
  font-size: 22px;
  text-align: center;
}

.bottom-section {
  margin-top: 6px;
  margin-bottom: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-btn {
  width: 80%;
  height: 70px;
  background-color: #333333;
  border-radius: 12px;
  padding: 15px 20px;
  justify-content: center;
  align-items: center;
}

.back-text {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
}
</style>
