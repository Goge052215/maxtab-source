<template>
  <div class="container" @swipe="handleSwipe">
    <div class="top-bar">
      <text class="title">{{ i18n.pages.hypothesis.z_test }}</text>
    </div>

    <scroll class="scroll-container" scroll-y="{{ true }}">
      <div class="scroll-content">
        <div class="content">
          
          <!-- Summary Display (Read Only) -->
          <div class="section-group">
            <text class="section-title">{{ i18n.pages.hypothesis.summary_stats }}</text>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.mean }} 1</text>
                <text class="menu-value">{{ mean }}</text>
              </div>
            </div>
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.n }} 1</text>
                <text class="menu-value">{{ n }}</text>
              </div>
            </div>
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.sigma }} 1</text>
                <text class="menu-value">{{ sigma }}</text>
              </div>
            </div>
            
            <div class="menu-list-item" if="{{ isTwoSample }}">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.mean }} 2</text>
                <text class="menu-value">{{ mean2 }}</text>
              </div>
            </div>
            <div class="menu-list-item" if="{{ isTwoSample }}">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.n }} 2</text>
                <text class="menu-value">{{ n2 }}</text>
              </div>
            </div>
            <div class="menu-list-item" if="{{ isTwoSample }}">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.sigma }} 2</text>
                <text class="menu-value">{{ sigma2 }}</text>
              </div>
            </div>
            
            <div class="menu-list-item" if="{{ !isTwoSample }}">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.hypothesized_mean }} (mu0)</text>
                <text class="menu-value">{{ muZero }}</text>
              </div>
            </div>
          </div>

          <div class="section-group">
            <text class="section-title">{{ i18n.pages.hypothesis.procedure }}</text>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.test_type }}</text>
                <text class="menu-value">{{ testTypeLabel }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.tail_type }}</text>
                <text class="menu-value">{{ tailTypeLabel }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.significance_level }}</text>
                <text class="menu-value">{{ alpha }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.null_hypothesis }}</text>
                <text class="menu-value small-text">{{ hypothesisNull }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.alternative_hypothesis }}</text>
                <text class="menu-value small-text">{{ hypothesisAlt }}</text>
              </div>
            </div>
          </div>

          <!-- Results Section -->
          <div class="result-section" if="{{ hasResult }}">
            <text class="result-title">{{ i18n.common.calculation_result }}</text>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">Z {{ i18n.pages.hypothesis.test_statistic }}</text>
                <text class="menu-value result-number">{{ resultZ }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.two_tail }} P</text>
                <text class="menu-value result-number">{{ pValueTwoTail }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.left_tail }} P</text>
                <text class="menu-value result-number">{{ pValueLeft }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.right_tail }} P</text>
                <text class="menu-value result-number">{{ pValueRight }}</text>
              </div>
            </div>

            <div class="menu-list-item" if="{{ lowerCI !== null }}">
              <div class="menu-item">
                <text class="menu-label">95% CI</text>
                <text class="menu-value small-text result-number">[{{ lowerCI }}, {{ upperCI }}]</text>
              </div>
            </div>

            <div class="menu-list-item highlight">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.conclusion }} (α=0.05)</text>
                <text class="menu-value small-text result-number">{{ conclusion }}</text>
              </div>
            </div>
          </div>

          <!-- Error Message -->
          <div class="error-message" if="{{ errorMessage }}">
            <text class="error-text">{{ errorMessage }}</text>
          </div>

          <!-- Back Button -->
          <div class="bottom-section">
            <div class="back-btn" onclick="goBack">
              <text class="back-text">{{ backTextLabel }}</text>
            </div>
          </div>
        </div>
      </div>
    </scroll>
  </div>
</template>

<script>
import router from "@system.router"
import HypothesisEngine from "../../../common/hypothesis_engine"
import i18nService from "../../../common/i18n"

export default {
  protected: {
    mean: 0,
    n: 30,
    sigma: 1,
    mu0: 0,
    muZero: 0,
    // Two Sample Params
    isTwoSample: false,
    mean2: 0,
    n2: 30,
    sigma2: 1,
    diff: 0,
    alpha: 0.05,
    tailType: "two_tail"
  },
  private: {
    resultZ: "-",
    pValueTwoTail: "-",
    pValueLeft: "-",
    pValueRight: "-",
    lowerCI: null,
    upperCI: null,
    testTypeLabel: "",
    tailTypeLabel: "",
    hypothesisNull: "",
    hypothesisAlt: "",
    backTextLabel: "",
    conclusion: "",
    hasResult: false,
    errorMessage: "",
    i18n: i18nService.getLocaleStrings()
  },

  onInit() {
    this.muZero = this.mu0
    this.refreshI18n()
    // Auto calculate on load
    this.calculate()
  },

  onShow() {
    this.muZero = this.mu0
    this.refreshI18n()
  },

  refreshI18n() {
    this.i18n = i18nService.getLocaleStrings()
    this.backTextLabel = this.i18n.common && this.i18n.common.back ? this.i18n.common.back : "Back"
    // @ts-ignore QuickApp runtime API
    this.$page.setTitleBar({ text: i18nService.t('pages.hypothesis.z_test') })
    // @ts-ignore QuickApp runtime API
    this.$forceUpdate()
  },

  goBack() {
    router.back()
  },

  handleSwipe() {
    const event = arguments[0] || {}
    if (event.direction === 'right') {
      this.goBack()
    }
  },

  calculate() {
    try {
      this.errorMessage = ""
      this.hasResult = false

      let result = null
      const mean = Number(this.mean)
      const n = Number(this.n)
      const sigma = Number(this.sigma)
      const mu0 = Number(this.mu0)
      const mean2 = Number(this.mean2)
      const n2 = Number(this.n2)
      const sigma2 = Number(this.sigma2)
      const diff = Number(this.diff || 0)
      const tailType = String(this.tailType || "two_tail")

      this.testTypeLabel = this.isTwoSample
        ? `${this.i18n.pages.hypothesis.two_sample} Z-Test`
        : `${this.i18n.pages.hypothesis.one_sample} Z-Test`
      this.tailTypeLabel = tailType === "left_tail"
        ? this.i18n.pages.hypothesis.left_tail
        : tailType === "right_tail"
          ? this.i18n.pages.hypothesis.right_tail
          : this.i18n.pages.hypothesis.two_tail
      if (tailType === "left_tail") {
        if (this.isTwoSample) {
          this.hypothesisNull = `mu1 - mu2 >= ${diff}`
          this.hypothesisAlt = `mu1 - mu2 < ${diff}`
        } else {
          this.hypothesisNull = `mu >= mu0`
          this.hypothesisAlt = `mu < mu0`
        }
      } else if (tailType === "right_tail") {
        if (this.isTwoSample) {
          this.hypothesisNull = `mu1 - mu2 <= ${diff}`
          this.hypothesisAlt = `mu1 - mu2 > ${diff}`
        } else {
          this.hypothesisNull = `mu <= mu0`
          this.hypothesisAlt = `mu > mu0`
        }
      } else {
        if (this.isTwoSample) {
          this.hypothesisNull = `mu1 - mu2 = ${diff}`
          this.hypothesisAlt = `mu1 - mu2 != ${diff}`
        } else {
          this.hypothesisNull = `mu = mu0`
          this.hypothesisAlt = `mu != mu0`
        }
      }
      
      if (this.isTwoSample) {
          result = HypothesisEngine.zTestTwoSample({
              mean1: mean,
              n1: n,
              sigma1: sigma,
              mean2: mean2,
              n2: n2,
              sigma2: sigma2,
              diff: diff
          })
      } else {
          result = HypothesisEngine.zTestOneSample({
              mean: mean,
              n: n,
              sigma: sigma,
              mu0: mu0
          })
      }

      const r = /** @type {any} */ (result)
      if (r.error) {
        this.errorMessage = i18nService.t(`errors.${r.error}`) || r.error
        return
      }

      this.resultZ = r.z.toFixed(4)
      this.pValueTwoTail = r.pValueTwoTail.toFixed(4)
      this.pValueLeft = r.pValueLeft.toFixed(4)
      this.pValueRight = r.pValueRight.toFixed(4)
      
      if (r.lowerCI !== null && r.upperCI !== null) {
        this.lowerCI = r.lowerCI.toFixed(4)
        this.upperCI = r.upperCI.toFixed(4)
      } else {
        this.lowerCI = null
        this.upperCI = null
      }
      
      const selectedPValue = tailType === "left_tail"
        ? r.pValueLeft
        : tailType === "right_tail"
          ? r.pValueRight
          : r.pValueTwoTail

      if (selectedPValue < this.alpha) {
          this.conclusion = this.i18n.pages.hypothesis.reject
      } else {
          this.conclusion = this.i18n.pages.hypothesis.fail_to_reject
      }

      this.hasResult = true
    } catch (e) {
      const err = e instanceof Error ? e.message : String(e)
      this.errorMessage = "Calculation Error: " + err
      this.hasResult = false
    }
  }
}
</script>

<style>
.container {
  display: flex;
  flex-direction: column;
  background-color: #000000;
  height: 100%;
}

.top-bar {
  height: 80px;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 15px 20px;
}

.title {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
}

.scroll-container {
  flex: 1;
  width: 100%;
  flex-direction: column;
}

.scroll-content {
  flex-direction: column;
  width: 100%;
}

.content {
  flex-direction: column;
  padding: 16px 12px;
}

.section-group {
  flex-direction: column;
  margin-bottom: 20px;
}

.section-title {
  font-size: 24px;
  color: #aaaaaa;
  margin-bottom: 10px;
  font-weight: bold;
}

.menu-list-item {
  margin-bottom: 20px;
}

.menu-item {
  display: flex;
  min-height: 95px;
  width: 100%;
  background-color: #222222;
  border-radius: 12px;
  padding: 15px 20px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 1px solid #333333;
}

.menu-label {
  font-size: 24px;
  color: #ffffff;
}

.menu-value {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
  text-align: center;
}

.menu-value.result-number {
  font-size: 30px;
}

.menu-value.small-text {
  font-size: 20px;
}

.menu-value.small-text.result-number {
  font-size: 24px;
}
.result-section {
  flex-direction: column;
  margin-bottom: 20px;
  background-color: #1a1a1a;
  border-radius: 12px;
  padding: 15px;
  border: 1px solid #333333;
}

.result-title {
  font-size: 24px;
  color: #00ff88;
  margin-bottom: 15px;
  font-weight: bold;
  text-align: center;
}

.menu-list-item.highlight .menu-item {
  border-color: #444444;
}

.error-message {
  padding: 20px;
  background-color: #331111;
  border-radius: 8px;
  margin-bottom: 20px;
}

.error-text {
  color: #ff4444;
  font-size: 22px;
  text-align: center;
}

.bottom-section {
  margin-top: 6px;
  margin-bottom: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-btn {
  width: 80%;
  height: 70px;
  background-color: #333333;
  border-radius: 12px;
  padding: 15px 20px;
  justify-content: center;
  align-items: center;
}

.back-text {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
}
</style>
