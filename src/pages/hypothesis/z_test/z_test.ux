<template>
  <div class="container" @swipe="handleSwipe">
    <div class="top-bar">
      <text class="title">{{ i18n.pages.hypothesis.z_test }}</text>
    </div>

    <scroll class="scroll-container" scroll-y="true">
      <div class="scroll-content">
        <div class="content">
          
          <!-- Summary Display (Read Only) -->
          <div class="section-group">
            <text class="section-title">{{ i18n.pages.hypothesis.summary_stats }}</text>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.mean }} 1</text>
                <text class="menu-value">{{ mean }}</text>
              </div>
            </div>
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.n }} 1</text>
                <text class="menu-value">{{ n }}</text>
              </div>
            </div>
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.sigma }} 1</text>
                <text class="menu-value">{{ sigma }}</text>
              </div>
            </div>
            
            <div class="menu-list-item" if="{{ isTwoSample }}">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.mean }} 2</text>
                <text class="menu-value">{{ mean2 }}</text>
              </div>
            </div>
            <div class="menu-list-item" if="{{ isTwoSample }}">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.n }} 2</text>
                <text class="menu-value">{{ n2 }}</text>
              </div>
            </div>
            <div class="menu-list-item" if="{{ isTwoSample }}">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.sigma }} 2</text>
                <text class="menu-value">{{ sigma2 }}</text>
              </div>
            </div>
            
            <div class="menu-list-item" if="{{ !isTwoSample }}">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.hypothesized_mean }} (μ₀)</text>
                <text class="menu-value">{{ mu0 }}</text>
              </div>
            </div>
          </div>

          <!-- Results Section -->
          <div class="result-section" if="{{ hasResult }}">
            <text class="result-title">{{ i18n.common.calculation_result }}</text>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">Z {{ i18n.pages.hypothesis.test_statistic }}</text>
                <text class="menu-value result-number">{{ resultZ }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.two_tail }} P</text>
                <text class="menu-value result-number">{{ pValueTwoTail }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.left_tail }} P</text>
                <text class="menu-value result-number">{{ pValueLeft }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.right_tail }} P</text>
                <text class="menu-value result-number">{{ pValueRight }}</text>
              </div>
            </div>

            <div class="menu-list-item" if="{{ lowerCI !== null }}">
              <div class="menu-item">
                <text class="menu-label">95% CI</text>
                <text class="menu-value small-text result-number">[{{ lowerCI }}, {{ upperCI }}]</text>
              </div>
            </div>

            <div class="menu-list-item highlight">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.conclusion }} (α=0.05)</text>
                <text class="menu-value small-text result-number">{{ conclusion }}</text>
              </div>
            </div>
          </div>

          <!-- Error Message -->
          <div class="error-message" if="{{ errorMessage }}">
            <text class="error-text">{{ errorMessage }}</text>
          </div>

          <!-- Back Button -->
          <div class="bottom-section">
            <div class="back-btn" onclick="goBack">
              <text class="back-text">{{ i18n.common.back }}</text>
            </div>
          </div>
        </div>
      </div>
    </scroll>
  </div>
</template>

<script>
import router from "@system.router"
import HypothesisEngine from "../../../common/hypothesis_engine"
import i18n from "../../../common/i18n"

export default {
  protected: {
    mean: 0,
    n: 30,
    sigma: 1,
    mu0: 0,
    // Two Sample Params
    isTwoSample: false,
    mean2: 0,
    n2: 30,
    sigma2: 1,
    diff: 0,
    alpha: 0.05
  },
  private: {
    resultZ: "-",
    pValueTwoTail: "-",
    pValueLeft: "-",
    pValueRight: "-",
    lowerCI: null,
    upperCI: null,
    conclusion: "",
    hasResult: false,
    errorMessage: "",
    i18n: i18n.getLocaleStrings()
  },

  onInit() {
    this.refreshI18n()
    // Auto calculate on load
    this.calculate()
  },

  onShow() {
    this.refreshI18n()
  },

  refreshI18n() {
    this.i18n = i18n.getLocaleStrings()
    this.$page.setTitleBar({ text: i18n.t('pages.hypothesis.z_test') })
    this.$forceUpdate()
  },

  goBack() {
    router.back()
  },

  handleSwipe(event) {
    if (event.direction === 'right') {
      this.goBack()
    }
  },

  calculate() {
    try {
      this.errorMessage = ""
      this.hasResult = false

      let result;
      
      if (this.isTwoSample) {
          result = HypothesisEngine.zTestTwoSample({
              mean1: parseFloat(this.mean),
              n1: parseInt(this.n),
              sigma1: parseFloat(this.sigma),
              mean2: parseFloat(this.mean2),
              n2: parseInt(this.n2),
              sigma2: parseFloat(this.sigma2),
              diff: parseFloat(this.diff || 0)
          })
      } else {
          result = HypothesisEngine.zTestOneSample({
              mean: parseFloat(this.mean),
              n: parseInt(this.n),
              sigma: parseFloat(this.sigma),
              mu0: parseFloat(this.mu0)
          })
      }

      if (result.error) {
        this.errorMessage = i18n.t(`errors.${result.error}`) || result.error
        return
      }

      this.resultZ = result.z.toFixed(4)
      this.pValueTwoTail = result.pValueTwoTail.toFixed(4)
      this.pValueLeft = result.pValueLeft.toFixed(4)
      this.pValueRight = result.pValueRight.toFixed(4)
      
      if (result.lowerCI !== null && result.upperCI !== null) {
        this.lowerCI = result.lowerCI.toFixed(4)
        this.upperCI = result.upperCI.toFixed(4)
      } else {
        this.lowerCI = null
        this.upperCI = null
      }
      
      // Determine conclusion based on two-tail p-value and alpha=0.05
      if (result.pValueTwoTail < this.alpha) {
          this.conclusion = this.i18n.pages.hypothesis.reject
      } else {
          this.conclusion = this.i18n.pages.hypothesis.fail_to_reject
      }

      this.hasResult = true
    } catch (e) {
      this.errorMessage = "Calculation Error: " + (e.message || e)
      this.hasResult = false
    }
  }
}
</script>

