<template>
  <div class="container" @swipe="handleSwipe">
    <div class="top-bar">
      <text class="title">{{ i18n.pages.hypothesis.f_test }}</text>
    </div>

    <scroll class="scroll-container" scroll-y="true">
      <div class="scroll-content">
        <div class="content">
          
          <!-- Summary Display (Read Only) -->
          <div class="section-group">
            <text class="section-title">{{ i18n.pages.hypothesis.summary_stats }}</text>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.n }} 1</text>
                <text class="menu-value">{{ n1 }}</text>
              </div>
            </div>
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.stddev }} 1</text>
                <text class="menu-value">{{ s1 }}</text>
              </div>
            </div>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.n }} 2</text>
                <text class="menu-value">{{ n2 }}</text>
              </div>
            </div>
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.params.stddev }} 2</text>
                <text class="menu-value">{{ s2 }}</text>
              </div>
            </div>
          </div>

          <!-- Results Section -->
          <div class="result-section" if="{{ hasResult }}">
            <text class="result-title">{{ i18n.common.calculation_result }}</text>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">F {{ i18n.pages.hypothesis.test_statistic }}</text>
                <text class="menu-value result-number">{{ resultF }}</text>
              </div>
            </div>
            
            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">df 1</text>
                <text class="menu-value result-number">{{ resultDf1 }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">df 2</text>
                <text class="menu-value result-number">{{ resultDf2 }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.two_tail }} P</text>
                <text class="menu-value result-number">{{ pValueTwoTail }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.left_tail }} P</text>
                <text class="menu-value result-number">{{ pValueLeft }}</text>
              </div>
            </div>

            <div class="menu-list-item">
              <div class="menu-item">
                <text class="menu-label">{{ i18n.pages.hypothesis.right_tail }} P</text>
                <text class="menu-value result-number">{{ pValueRight }}</text>
              </div>
            </div>
          </div>

          <!-- Error Message -->
          <div class="error-message" if="{{ errorMessage }}">
            <text class="error-text">{{ errorMessage }}</text>
          </div>

          <!-- Back Button -->
          <div class="bottom-section">
            <div class="back-btn" onclick="goBack">
              <text class="back-text">{{ i18n.common.back }}</text>
            </div>
          </div>
        </div>
      </div>
    </scroll>
  </div>
</template>

<script>
import router from "@system.router"
import HypothesisEngine from "../../../common/hypothesis_engine"
import i18n from "../../../common/i18n"

export default {
  protected: {
    n1: 30,
    s1: 1,
    n2: 30,
    s2: 1,
    alpha: 0.05
  },
  private: {
    resultF: "-",
    resultDf1: "-",
    resultDf2: "-",
    pValueTwoTail: "-",
    pValueLeft: "-",
    pValueRight: "-",
    conclusion: "",
    hasResult: false,
    errorMessage: "",
    i18n: i18n.getLocaleStrings()
  },

  onInit() {
    this.refreshI18n()
    // Auto calculate on load
    this.calculate()
  },

  onShow() {
    this.refreshI18n()
  },

  refreshI18n() {
    this.i18n = i18n.getLocaleStrings()
    this.$page.setTitleBar({ text: i18n.t('pages.hypothesis.f_test') })
    this.$forceUpdate()
  },

  goBack() {
    router.back()
  },

  handleSwipe(event) {
    if (event.direction === 'right') {
      this.goBack()
    }
  },

  calculate() {
    try {
      this.errorMessage = ""
      this.hasResult = false

      const result = HypothesisEngine.fTestTwoSample({
        n1: parseInt(this.n1),
        s1: parseFloat(this.s1),
        n2: parseInt(this.n2),
        s2: parseFloat(this.s2)
      })

      if (result.error) {
        this.errorMessage = i18n.t(`errors.${result.error}`) || result.error
        return
      }

      this.resultF = result.f.toFixed(4)
      this.resultDf1 = result.df1.toFixed(0)
      this.resultDf2 = result.df2.toFixed(4)
      this.pValueTwoTail = result.pValueTwoTail.toFixed(4)
      this.pValueLeft = result.pValueLeft.toFixed(4)
      this.pValueRight = result.pValueRight.toFixed(4)
      
      // Determine conclusion based on two-tail p-value and alpha=0.05
      if (result.pValueTwoTail < this.alpha) {
          this.conclusion = this.i18n.pages.hypothesis.reject
      } else {
          this.conclusion = this.i18n.pages.hypothesis.fail_to_reject
      }

      this.hasResult = true
    } catch (e) {
      this.errorMessage = "Calculation Error: " + (e.message || e)
      this.hasResult = false
    }
  }
}
</script>

