.container {
  display: flex;
  flex-direction: column;
  background-color: #000000;
  height: 100%;
}

.top-bar {
  display: flex;
  height: 75px;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 15px 20px;
}

.page-title {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
}

.main-menu {
  display: flex;
  flex: 1;
  flex-direction: column;
  height: 0;
}

.scroll-container {
  flex: 1;
  width: 100%;
  flex-direction: column;
}

.menu-content {
  padding: 20px 20px 40px 20px;
  flex-direction: column;
}

.menu-header {
  margin-bottom: 20px;
  align-items: center;
  justify-content: center;
}

.menu-subtitle {
  color: #ffffff;
  font-size: 24px;
  font-weight: bold;
}

.menu-list-item {
  margin-bottom: 12px;
}

.menu-entry {
  cursor: pointer;
}

.menu-item {
  display: flex;
  min-height: 110px;
  width: 100%;
  background-color: #222222;
  border-radius: 12px;
  padding: 12px 18px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.menu-title {
  font-size: 24px;
  color: #ffffff;
  font-weight: bold;
  text-align: center;
  margin-bottom: 6px;
}

.menu-desc {
  font-size: 18px;
  color: #aaaaaa;
}

.back-item {
  min-height: 75px;
}
</style>
