  display: flex;
  flex: 1;
  flex-direction: column;
  height: 0;
}

.scroll-container {
  flex: 1;
  width: 100%;
  flex-direction: column;
}

.menu-content {
  padding: 20px 20px 40px 20px;
  flex-direction: column;
}

.menu-list-item {
  margin-bottom: 20px;
}

.menu-entry {
  cursor: pointer;
}

.menu-item {
  display: flex;
  height: 95px;
  width: 100%;
  background-color: #222222;
