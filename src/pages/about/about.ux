<template>
  <div class="container" @swipe="handleSwipe">
    <div class="top-bar">
      <text class="page-title">{{ i18n.pages.about.title }}</text>
    </div>

    <div class="main-menu">
      <scroll class="scroll-container" scroll-y="true">
        <div class="menu-content">
          <div class="menu-list-item">
            <div class="menu-item">
              <text class="menu-label">{{ i18n.pages.about.developer }}</text>
              <text class="menu-value">@goge</text>
            </div>
          </div>

          <div class="menu-list-item">
            <div class="menu-item">
              <text class="menu-label">{{ i18n.pages.about.version }}</text>
              <text class="menu-value">1.1.1</text>
            </div>
          </div>

          <div class="menu-list-item">
            <div class="menu-item">
              <text class="menu-label">{{ i18n.pages.about.date }}</text>
              <text class="menu-value">2026.02</text>
            </div>
          </div>

          <div class="menu-list-item menu-entry" onclick="goBack">
            <div class="menu-item">
              <text class="menu-title">{{ i18n.common.back }}</text>
            </div>
          </div>
        </div>
      </scroll>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import i18n from '../../common/i18n'

export default {
  private: {
    i18n: i18n.getLocaleStrings()
  },

  onInit() {
    this.refreshI18n()
  },

  onShow() {
    this.refreshI18n()
  },

  refreshI18n() {
    this.i18n = i18n.getLocaleStrings()
    this.$page.setTitleBar({ text: i18n.t('pages.about.title') })
    this.$forceUpdate()
  },

  handleSwipe(event) {
    if (event.direction === 'right') {
      this.goBack();
    }
  },

  goBack() {
    router.back()
  }
}
</script>

